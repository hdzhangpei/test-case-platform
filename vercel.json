{
  "version": 2,
  "installCommand": "npm install && cd tools/api-test-framework && npm install",
  "buildCommand": "cd tools/api-test-framework && npx tsc",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
