{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digital-user.xiaomi.com/http-scenario/v1",
  "title": "HTTP Scenario Test Case Schema",
  "description": "数字用户中心 HTTP 网关场景测试用例 YAML 格式定义",
  "type": "object",
  "required": ["version", "metadata", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2.0"],
      "description": "Schema 版本号（2.0 = HTTP 场景）"
    },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "requirement"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*-\\d{3}$",
          "description": "场景唯一 ID，格式：{场景名}-{3位序号}，必须与文件名一致"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "场景中文名称"
        },
        "requirement": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "需求名"
        },
        "author": {
          "type": "string",
          "description": "作者"
        },
        "created": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "创建日期 YYYY-MM-DD"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "标签列表"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": {
          "type": "string",
          "description": "测试环境基础 URL（支持 ${env:VAR} 模板）"
        },
        "cookieEnv": {
          "type": "string",
          "description": "Cookie 环境变量名（运行时从该环境变量读取 Cookie）"
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "全局请求头（所有步骤共享，步骤级 headers 可覆盖）"
        }
      }
    },
    "fixtures": {
      "type": "object",
      "description": "前置数据（通过 ${fixture:path} 引用）",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "测试步骤列表（按顺序执行）",
      "items": {
        "$ref": "#/definitions/step"
      }
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["id", "name", "request"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "步骤唯一 ID（在同一场景内唯一）"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "步骤中文名称"
        },
        "request": {
          "$ref": "#/definitions/request"
        },
        "expected": {
          "$ref": "#/definitions/expected"
        },
        "capture": {
          "type": "object",
          "description": "从响应中捕获值，供后续步骤通过 ${capture:name} 引用",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "request": {
      "type": "object",
      "required": ["method", "path"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "description": "HTTP 方法"
        },
        "path": {
          "type": "string",
          "description": "请求路径（会拼接到 baseUrl 后面，支持模板变量）"
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "步骤级请求头（覆盖全局 headers）"
        },
        "body": {
          "description": "请求体（JSON，支持模板变量 ${capture:xxx} / ${fixture:xxx} / ${env:xxx}）"
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "number",
          "description": "期望 HTTP 状态码（默认 200）"
        },
        "assertions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/assertion"
          },
          "description": "响应断言列表"
        }
      }
    },
    "assertion": {
      "type": "object",
      "required": ["type", "target"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["not_null", "equals", "contains", "true", "false", "greater_than"],
          "description": "断言类型"
        },
        "target": {
          "type": "string",
          "description": "断言目标 JSON path（如 code、data.list[0].agentId）"
        },
        "value": {
          "description": "期望值（equals/contains/greater_than 时需要）"
        }
      }
    }
  }
}
