{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digital-user.xiaomi.com/test-case/v1",
  "title": "API Test Case Schema",
  "description": "数字用户中心 API 测试用例 YAML 格式定义",
  "type": "object",
  "required": ["version", "metadata", "target", "input", "invocation", "expected"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Schema 版本号"
    },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "requirement", "priority", "group", "author", "created"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*-\\d{3}$",
          "description": "用例唯一 ID，格式：{需求名}-{3位序号}，必须与文件名一致"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "用例中文名称"
        },
        "requirement": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "需求名，对应 changesets/<month>/<requirement>"
        },
        "priority": {
          "enum": ["P0", "P1", "P2"],
          "description": "优先级"
        },
        "group": {
          "enum": ["SMOKE", "REGRESSION", "EDGE_CASE"],
          "description": "测试分组"
        },
        "author": {
          "type": "string",
          "description": "作者"
        },
        "created": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "创建日期 YYYY-MM-DD"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "标签列表"
        }
      }
    },
    "target": {
      "type": "object",
      "required": ["service", "method", "bean_class"],
      "additionalProperties": false,
      "properties": {
        "service": {
          "type": "string",
          "description": "Spring Bean / Dubbo Service 接口名"
        },
        "method": {
          "type": "string",
          "description": "被测方法名"
        },
        "bean_class": {
          "type": "string",
          "pattern": "^com\\.xiaomi\\.",
          "description": "Bean 完整类路径"
        }
      }
    },
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "login_user": {
          "type": "object",
          "properties": {
            "account": { "type": "string" }
          },
          "required": ["account"]
        },
        "fixtures": {
          "type": "array",
          "items": { "type": "string" },
          "description": "前置 SQL 文件列表"
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "input": {
      "type": "object",
      "required": ["type", "fields"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^com\\.xiaomi\\.",
          "description": "入参 DTO 完整类路径"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/fieldDef"
          },
          "description": "字段赋值列表"
        },
        "wrapper": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "pattern": "^com\\.xiaomi\\.",
              "description": "包装器类路径"
            },
            "source": {
              "type": "string",
              "description": "来源标识"
            },
            "header_fields": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/fieldDef"
              }
            }
          },
          "required": ["type"]
        }
      }
    },
    "invocation": {
      "type": "object",
      "required": ["style", "return_type"],
      "additionalProperties": false,
      "properties": {
        "style": {
          "enum": ["direct", "dubbo_reference"],
          "description": "调用方式"
        },
        "return_type": {
          "type": "string",
          "description": "返回值类型"
        }
      }
    },
    "expected": {
      "type": "object",
      "required": ["assertions"],
      "additionalProperties": false,
      "properties": {
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/assertionDef"
          }
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fixtures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "method": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "备注（包含 mvn 命令等）"
    }
  },
  "definitions": {
    "fieldDef": {
      "type": "object",
      "required": ["field", "value", "type"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string",
          "description": "字段名（对应 Java setter）"
        },
        "value": {
          "description": "字段值（支持基础类型、数组、特殊标记 UUID/NOW）"
        },
        "type": {
          "type": "string",
          "description": "Java 类型声明"
        },
        "items": {
          "type": "array",
          "description": "复杂嵌套对象列表",
          "items": {
            "type": "object",
            "properties": {
              "constructor_args": {
                "type": "array"
              },
              "fields": {
                "type": "array",
                "items": { "$ref": "#/definitions/fieldDef" }
              }
            }
          }
        }
      }
    },
    "assertionDef": {
      "type": "object",
      "required": ["type", "target"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["not_null", "equals", "contains", "true", "false", "greater_than"],
          "description": "断言类型"
        },
        "target": {
          "type": "string",
          "description": "断言目标表达式"
        },
        "value": {
          "description": "期望值（equals/contains/greater_than 时需要）"
        }
      }
    }
  }
}
